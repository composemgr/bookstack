# BookStack - Simple wiki and documentation platform
# Copy to app.env and fill in your values

# Timezone
TZ=America/New_York

# Hostname / domain
BASE_HOST_NAME=$HOSTNAME

# User/group IDs for file permissions
SERVICE_USER=1000
SERVICE_GROUP=1000

# Database credentials
DB_CREATE_DATABASE_NAME=bookstack
DB_USER_NAME=bookstack
DB_USER_PASS=changeme_db_password
DB_ADMIN_PASS=changeme_admin_password

# Application secret key (must be at least 32 characters, base64-encoded is fine)
APP_SECRET_KEY=changeme_secret_key_min_32_chars

# Email server settings
EMAIL_SERVER_HOST=172.17.0.1
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASS=
